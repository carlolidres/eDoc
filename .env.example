# Public frontend values only. Never put admin or secret keys in VITE_ variables.
VITE_GITHUB_PAGES_BASE=/
VITE_NHOST_SUBDOMAIN=your-nhost-subdomain
VITE_NHOST_REGION=your-nhost-region
VITE_HASURA_GRAPHQL_URL=https://your-nhost-subdomain.hasura.your-nhost-region.nhost.run/v1/graphql
VITE_WORKER_API_URL=http://127.0.0.1:8787
VITE_SESSION_TIMEOUT_MINUTES=15
