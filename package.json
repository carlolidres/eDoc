{
  "name": "edoc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "type-check": "tsc --noEmit -p tsconfig.app.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "worker:dev": "wrangler dev worker/src/index.ts --config worker/wrangler.toml",
    "worker:check": "tsc -p worker/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nhost/nhost-js": "^3.3.1",
    "@tanstack/react-query": "^5.83.0",
    "graphql-request": "^7.2.0",
    "hono": "^4.8.4",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "react-router-dom": "^6.26.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.46.1",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.5.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.1.0",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
